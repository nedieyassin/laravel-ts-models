{
  "name": "nedieyassin/laravel-ts-models",
  "description": "Generate TypeScript interfaces from Laravel Models",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0|^12.0",
    "illuminate/database": "^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Nedieyassin\\LaravelTsModels\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nedieyassin\\LaravelTsModels\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Nedieyassin\\LaravelTsModels\\TsModelsServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}